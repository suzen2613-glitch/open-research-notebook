[Unit]
Description=Open Notebook SurrealDB
PartOf=open-notebook.target
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/env bash __PROJECT_DIR__/system/open-notebook-systemd-run.sh surreal
SyslogIdentifier=open-notebook-surreal
StandardOutput=journal
StandardError=journal
Restart=on-failure
RestartSec=3
KillMode=control-group
TimeoutStopSec=20

[Install]
WantedBy=open-notebook.target
