[Unit]
Description=Open Notebook API
PartOf=open-notebook.target
After=open-notebook-surreal.service network.target
Requires=open-notebook-surreal.service

[Service]
Type=simple
ExecStart=/usr/bin/env bash __PROJECT_DIR__/system/open-notebook-systemd-run.sh api
Restart=always
RestartSec=3
KillMode=control-group
TimeoutStopSec=20

[Install]
WantedBy=open-notebook.target
